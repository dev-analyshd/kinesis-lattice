# ======================================================
# KINESIS — The Living Delegation Lattice
# Environment Configuration
# ======================================================

# Terminal 3 API Key
# Claim yours at: https://www.terminal3.io/claim-page
T3N_API_KEY=0x_your_api_key_here

# T3N Environment (testnet | production)
T3N_ENVIRONMENT=testnet

# Agent DID (auto-set after first spawn)
T3N_DID=

# Agent Configuration
AGENT_NAME=kinesis-core
AGENT_VERSION=0.1.0

# Demo Mode — set to 'true' for mock agents (no API key needed)
MOCK_DATA_FOR_DEMO=true
DEMO_AGENT_COUNT=5

# Server Ports
API_PORT=8080
DASHBOARD_PORT=3000

# Dashboard URLs
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Logging
LOG_LEVEL=info

# Session Secret (for production)
SESSION_SECRET=change-this-in-production
