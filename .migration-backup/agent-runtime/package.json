{
  "name": "@kinesis/agent-runtime",
  "version": "0.1.0",
  "description": "KINESIS agent runtime with full T3N SDK integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:adversarial": "jest --coverage --verbose --testNamePattern=adversarial",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@terminal3/t3n-sdk": "file:./t3n-sdk-mock",
    "@terminal3/bbs_vc": "file:./t3n-sdk-mock",
    "@terminal3/vc_core": "file:./t3n-sdk-mock",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ws": "^8.17.0",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.5",
    "axios": "^1.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.8",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "eslint": "^9.4.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0"
  }
}
