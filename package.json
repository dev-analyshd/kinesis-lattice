{
  "name": "@kinesis/lattice-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "agent-runtime",
    "sdk",
    "tests/integration"
  ],
  "scripts": {
    "bootstrap": "npm install && npm run build:all",
    "build:all": "npm run build:contracts && npm run build:runtime && npm run build:sdk",
    "build:contracts": "cd contracts && cargo build --target wasm32-wasip2 --release",
    "build:runtime": "cd agent-runtime && npm run build",
    "build:sdk": "cd sdk && npm run build",
    "build:dashboard": "cd dashboard && npm run build",
    "test:all": "npm run test:contracts && npm run test:runtime",
    "test:contracts": "cd contracts && cargo test",
    "test:runtime": "cd agent-runtime && npm test",
    "test:integration": "cd tests/integration && npm test",
    "demo": "node -e \"process.env.MOCK_DATA_FOR_DEMO='true'; process.env.DEMO_AGENT_COUNT='5';\" && cd agent-runtime && node dist/index.js",
    "demo:live": "MOCK_DATA_FOR_DEMO=false cd agent-runtime && node dist/index.js",
    "deploy:contracts": "node scripts/deploy/deploy-tee-contracts.js",
    "setup:identity": "node scripts/setup/setup-agent-identity.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "eslint": "^9.4.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "prettier": "^3.3.0",
    "concurrently": "^8.2.2"
  }
}
